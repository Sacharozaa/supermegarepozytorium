<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Pokédle</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header>
      <div class="header-top">
        <div class="header-title">
          <img src="/pokedle.png" alt="Pokedle" class="logo">
          <div>
          </div>
        </div>
      </div>
      <nav>
        <a href="/" class="nav-btn">Gra</a>
        <a href="/pokedex" class="nav-btn">Pokédex</a>
        <a href="/add" class="nav-btn">Dodaj</a>
        <a href="/stats" class="nav-btn">Statystyki</a>

        <% if (typeof username !== 'undefined' && username) { %>
          <a href="/my-pokemons" class="nav-btn">Moje Pokemony</a>
          <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
            <a href="/admin" class="nav-btn">Admin</a>
          <% } %>
          <div style="margin-left: auto; display: flex; align-items: center; gap: 10px;">
            <span style="color: var(--white); font-size: 12px; font-weight: bold;"><%= username %></span>
            <a href="/logout" class="nav-btn">Wyloguj</a>
          </div>
        <% } else { %>
          <div style="margin-left: auto; display: flex; gap: 8px;">
            <a href="/login" class="nav-btn">Zaloguj</a>
            <a href="/register" class="nav-btn">Rejestracja</a>
          </div>
        <% } %>
      </nav>
    </header>

    <main><%- body %></main>
  </body>
</html>
